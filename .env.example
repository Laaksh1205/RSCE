GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here  # optional
PUBMED_EMAIL=your_email@example.com
PUBMED_API_KEY=optional_ncbi_key

# Gemini Rate Limiting (seconds between requests, default: 4.2)
# Set to 0.0 to disable rate limiting (e.g., for testing)
GEMINI_RATE_LIMIT_INTERVAL=4.2

# Gemini Key Pool for Rotation (optional)
GEMINI_API_KEY_1=your_key_1_here
GEMINI_API_KEY_2=your_key_2_here
GEMINI_API_KEY_3=your_key_3_here

# PubMed Key Pool for Rotation (optional)
PUBMED_EMAIL_1=your_email_1@example.com
PUBMED_API_KEY_1=your_key_1_here
PUBMED_EMAIL_2=your_email_2@example.com
PUBMED_API_KEY_2=your_key_2_here

# CORS Settings
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
