# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's system of choice. But for a run-once application,
#   maybe yes.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions, but can be useful
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact versions
pdm.lock
#   maintaining tentetive dependencies
.pdm-plugins/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

